# Базовый URL. Примеры:
# "https://generativelanguage.googleapis.com/v1beta/openai/" - для облачных моделей Gemini
# "http://127.0.0.1:11434/v1/" - для локальных моделей через Ollama
LLM_API_URL=""

# API Ключ
# Важно: оставьте поле пустым (просто ""), если используете локальную модель (Ollama, LM Studio)
LLM_API_KEY_1=""
# LLM_API_KEY_2=""
# LLM_API_KEY_3=""
# ...можно добавить сколько угодно разных, если используется облачная LLM

# [OPTIONAL] Отдельный провайдер для субагентов
# Если оставить пустым, субагенты будут использовать ключи и URL основного агента (если система субагентов включена в settings.yaml)
# SUB_LLM_API_URL="" # Например, главному агенту можно выдать ключ и url от Gemini, а субагентам - от OpenAI 
# SUB_LLM_API_KEY_1=""

# [OPTIONAL] Классический бот на Aiogram
AIOGRAM_BOT_TOKEN=""

# [OPTIONAL] Юзер-бот на Telethon
TELETHON_API_ID=""
TELETHON_API_HASH=""

# [OPTIONAL] Github API
GITHUB_TOKEN=""
# Для получения: GitHub -> Settings -> Developer settings -> Personal access tokens -> Tokens (classic)

# [OPTIONAL] Email
EMAIL_ACCOUNT="" # Например: agent.jawl@gmail.com
EMAIL_PASSWORD="" # Важно: необходимо использовать специально сгенерированный "Пароль приложения" (App Password с 2FA), а не ваш основной пароль от почты

# [OPTIONAL] Tavily API
TAVILY_API_KEY=""

# [OPTIONAL] WebHooks
WEBHOOK_SECRET="" # Придумайте любой сложный пароль